{
  "info": {
    "_postman_id": "b6a3b6a6-2b0b-4b5f-9cc1-0a9e1b0c8f2b",
    "name": "Microservices Lab",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "CTSE Lab 05 Microservices: Item (8081), Order (8082), Payment (8083) via API Gateway (8080). Base URL variable: {{baseUrl}}"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "itemId",
      "value": "0"
    },
    {
      "key": "orderId",
      "value": "1"
    },
    {
      "key": "paymentId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Item Service",
      "item": [
        {
          "name": "GET /items",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/items",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "items"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /items/:id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/items/{{itemId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "items",
                "{{itemId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 404', function () { pm.expect([200,404]).to.include(pm.response.code); });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /items (Bonus)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Headphones\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/items",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "items"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 or 200', function () { pm.expect([200,201]).to.include(pm.response.code); });"
                ]
              }
            }
          ]
        }
      ]
    },
