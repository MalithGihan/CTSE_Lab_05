              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 404', function () { pm.expect([200,404]).to.include(pm.response.code); });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /orders (Bonus)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"item\": \"Laptop\",\n  \"quantity\": 2,\n  \"customerId\": \"C001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 or 200', function () { pm.expect([200,201]).to.include(pm.response.code); });",
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  try {",
                  "    const data = pm.response.json();",
                  "    if (data && data.id) pm.collectionVariables.set('orderId', String(data.id));",
                  "  } catch (e) {}",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
